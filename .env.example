# ============================================
# NAKAMA — Variables d'environnement (.env.local)
# ============================================
# Copie ce fichier en .env.local et remplis chaque clé.
# Tout est requis sauf indication contraire.

# --- Supabase --------------------------------
# 1. https://supabase.com/dashboard → New project
# 2. Settings > API → copie "Project URL" et "anon public key"
# 3. Service role : Settings > API > Service role (jamais commiter, server-only)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string (pour Drizzle)
# Dashboard Supabase > Settings > Database > Connection string > URI
# Utilise le pooler (port 6543) pour Vercel serverless, direct (5432) pour migrations
DATABASE_URL=
DATABASE_URL_DIRECT=

# --- Mapbox ----------------------------------
# https://account.mapbox.com → Tokens → Create token
# Scope minimum : "styles:read", "geocoding"
MAPBOX_ACCESS_TOKEN=

# --- Cloudflare R2 (photos pros) -------------
# https://dash.cloudflare.com → R2 → Create bucket "nakama-photos"
# Manage R2 API tokens → Create API token (Object Read & Write)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=nakama-photos
# Public URL : Settings > Public access (configure custom domain or r2.dev)
NEXT_PUBLIC_R2_PUBLIC_URL=

# --- Resend (emails) -------------------------
# https://resend.com → API keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=Nakama <hello@nakama.tech>

# --- Cron secret (Vercel) --------------------
# Généré aléatoirement, header `Authorization: Bearer <secret>` côté Vercel cron
CRON_SECRET=

# --- App --------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
